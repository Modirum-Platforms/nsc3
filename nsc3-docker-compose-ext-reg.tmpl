### ReleaseTagStart rc
# Default configuration optimized for 16GB RAM configuration
# This is for nsc3 version 4.5 and later
# Example in docker-compose.yml
# Usage start all services
#   docker compose up -d
# Usage start only container, e.g nsc-scheduler-service:
#   docker compose nsc-scheduler-service up -d
# Usage stop all services
#   docker compose down
# Usage stop only container, e.g nsc-scheduler-service:
#   docker compose nsc-scheduler-service down

services:
  main-postgres:
    container_name: main-postgres
    image: $NSC3REG/dev/main-postgres:$NSC3REL
    logging:
      driver: "json-file"
      options: {}
    networks: 
      - nsc-network
    restart: unless-stopped
    volumes:
      - main-postgres-pg15-volume:/var/lib/postgresql/data:rw
    working_dir: /root
  bus-redis:
    container_name: bus-redis
    image: $NSC3REG/dev/bus-redis:$NSC3REL
    logging:
      driver: "json-file"
      options: {}
    networks: 
      - nsc-network
    restart: unless-stopped
    volumes:
      - bus-redis-volume:/data:rw
    working_dir: /root
  nsc-scheduler-service:
    container_name: nsc-scheduler-service
    image: $NSC3REG/dev/nsc-scheduler-service:$NSC3REL
    depends_on:
      dumps-perms:
        condition: service_completed_successfully
    mem_limit: 1024m
    memswap_limit: 1024m
    volumes:
      - dumps:/dumps:rw
    logging:
      driver: "json-file"
      options: {}
    networks: 
      - nsc-network
    restart: unless-stopped
    environment:
      NSC3_SCHEDULER_SERVICE_VALOR_ENABLED: $VALOR_ENABLED     
      QUARKUS_REDIS_MAX_POOL_WAITING: "2048"
      QUARKUS_REDIS_MAX_WAITING_HANDLERS: "4096"
      GC_OPTIONS: >-
        -XX:+UseZGC
        -XX:+ZGenerational
      QUARKUS_PROFILE: prod
      JAVA_TOOL_OPTIONS: >-
        -XX:+UseContainerSupport
        -XX:InitialRAMPercentage=20
        -XX:MaxRAMPercentage=70
        -XX:MinRAMPercentage=50
        -XX:+ExitOnOutOfMemoryError
        -XX:+HeapDumpOnOutOfMemoryError
        -XX:HeapDumpPath=/dumps
        -Xlog:os+container=info
    working_dir: /root
